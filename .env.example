# Copy to .env and fill in only the providers you intend to scan.
# The default "mock" target needs none of these.

GOOGLE_CLIENT_ID=        # Google OAuth (get from https://console.cloud.google.com/apis/credentials)
OPENAI_API_KEY=
OPENAI_BASE_URL=        # optional: point at any OpenAI-compatible endpoint
ANTHROPIC_API_KEY=
